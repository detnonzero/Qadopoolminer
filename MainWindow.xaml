<Window x:Class="Qadopoolminer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Qado Pool Miner"
        Height="920"
        Width="1280"
        MinHeight="760"
        MinWidth="1100"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,8,0">
                    <GroupBox Header="Pool Connection"
                              Margin="0,0,0,12">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     Margin="0,0,8,8"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PoolUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    MinWidth="140"
                                    Margin="0,0,0,8"
                                    Command="{Binding TestConnectionCommand}"
                                    Content="Test Connection" />

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    MinWidth="140"
                                    Command="{Binding LoadJobCommand}"
                                    Content="Load Job" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{Binding PoolConnectionStatus}" />

                            <TextBox Grid.Row="2"
                                     Grid.ColumnSpan="2"
                                     Margin="0,8,0,0"
                                     IsReadOnly="True"
                                     Text="{Binding LastError, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="48" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Miner Key"
                              Margin="0,0,0,12">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Margin="0,0,0,8"
                                       Text="{Binding StoredKeyStatus}" />

                            <TextBox Grid.Row="1"
                                     Margin="0,0,0,8"
                                     MinHeight="56"
                                     Text="{Binding PrivateKeyInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <WrapPanel Grid.Row="2"
                                       Margin="0,0,0,8">
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding GenerateKeyCommand}"
                                        Content="Generate" />
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding AcceptKeyCommand}"
                                        Content="Accept" />
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding DeleteKeyCommand}"
                                        Content="Delete" />
                                <Button MinWidth="120"
                                        Command="{Binding CopyPublicKeyCommand}"
                                        Content="Copy Public Key" />
                            </WrapPanel>

                            <TextBox Grid.Row="3"
                                     IsReadOnly="True"
                                     MinHeight="56"
                                     Text="{Binding CurrentPublicKey, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Auth / Verification"
                              Margin="0,0,0,12">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Margin="0,0,0,8"
                                       Text="{Binding MinerTokenStatus}" />

                            <TextBox Grid.Row="1"
                                     Margin="0,0,0,8"
                                     MinHeight="56"
                                     Text="{Binding MinerTokenInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <WrapPanel Grid.Row="2"
                                       Margin="0,0,0,12">
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding AcceptTokenCommand}"
                                        Content="Accept Token" />
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding DeleteTokenCommand}"
                                        Content="Delete Token" />
                                <Button MinWidth="100"
                                        Command="{Binding CopyTokenCommand}"
                                        Content="Copy Token" />
                            </WrapPanel>

                            <TextBlock Grid.Row="3"
                                       Margin="0,0,0,6"
                                       FontWeight="SemiBold"
                                       Text="Manual Dashboard Signature" />

                            <TextBlock Grid.Row="4"
                                       Margin="0,0,0,4"
                                       Text="Paste the challenge string from the pool dashboard, sign it locally, then paste the signature back into the dashboard." />

                            <TextBox Grid.Row="5"
                                     Margin="0,0,0,8"
                                     MinHeight="72"
                                     Text="{Binding ChallengeMessageInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <WrapPanel Grid.Row="6"
                                       Margin="0,0,0,8">
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding SignChallengeCommand}"
                                        Content="Sign" />
                                <Button MinWidth="120"
                                        Margin="0,0,8,0"
                                        Command="{Binding CopySignatureCommand}"
                                        Content="Copy Signature" />
                                <Button MinWidth="100"
                                        Command="{Binding ClearSignatureCommand}"
                                        Content="Clear" />
                            </WrapPanel>

                            <TextBox Grid.Row="7"
                                     IsReadOnly="True"
                                     MinHeight="72"
                                     Text="{Binding ManualSignatureHex, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="8,0,0,0">
                    <GroupBox Header="Mining Controls"
                              Margin="0,0,0,12">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,8,8"
                                       VerticalAlignment="Center"
                                       Text="Worker Threads" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,12,8"
                                     Text="{Binding WorkerThreadsText, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="0,0,0,8">
                                <Button MinWidth="120"
                                        Margin="0,0,8,0"
                                        Command="{Binding RefreshDevicesCommand}"
                                        Content="Refresh Devices" />
                                <Button MinWidth="100"
                                        Margin="0,0,8,0"
                                        Command="{Binding StartMiningCommand}"
                                        Content="Start" />
                                <Button MinWidth="100"
                                        Command="{Binding StopMiningCommand}"
                                        Content="Stop" />
                            </WrapPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,8"
                                       Text="{Binding SelectedDeviceSummary}" />

                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,4"
                                       Text="OpenCL Devices" />

                            <ListBox Grid.Row="3"
                                     Grid.ColumnSpan="3"
                                     ItemsSource="{Binding OpenClDevices}"
                                     MinHeight="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Selected}"
                                                  Content="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Live Stats">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Mining" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding IsMining}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Public Key" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,6"
                                     IsReadOnly="True"
                                     Text="{Binding CurrentPublicKey, Mode=OneWay}"
                                     TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Token" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding MinerTokenStatus}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Job Id" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,0,0,6"
                                     IsReadOnly="True"
                                     Text="{Binding CurrentJobId, Mode=OneWay}"
                                     TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Height" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding CurrentHeight}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Job Timestamp" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding CurrentJobTimestamp}" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Share Difficulty" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding ShareDifficultyText}" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Local Hashrate" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding LocalHashrateText}" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Pool Estimated Hashrate" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding PoolEstimatedHashrateText}" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="A / S / I / D" />
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding ShareCountersText}" />

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Block Candidates" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding BlockCandidates}" />

                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Pool Round A / S / I" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding PoolRoundSummaryText}" />

                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Last Share UTC" />
                            <TextBlock Grid.Row="12"
                                       Grid.Column="1"
                                       Margin="0,0,0,6"
                                       Text="{Binding LastShareUtcText}" />

                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Last Error" />
                            <TextBox Grid.Row="13"
                                     Grid.Column="1"
                                     Margin="0,0,0,6"
                                     IsReadOnly="True"
                                     Text="{Binding LastErrorDisplay, Mode=OneWay}"
                                     TextWrapping="Wrap" />

                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       Margin="0,0,8,6"
                                       Text="Targets" />
                            <StackPanel Grid.Row="14"
                                        Grid.Column="1">
                                <TextBox Margin="0,0,0,4"
                                         IsReadOnly="True"
                                         Text="{Binding CurrentShareTarget, Mode=OneWay}"
                                         TextWrapping="Wrap" />
                                <TextBox IsReadOnly="True"
                                         Text="{Binding CurrentNetworkTarget, Mode=OneWay}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <GroupBox Grid.Row="1"
                  Header="Logs"
                  Margin="0,12,0,0">
            <ListBox x:Name="LogListBox"
                     ItemsSource="{Binding Logs}"
                     DisplayMemberPath="Text" />
        </GroupBox>
    </Grid>
</Window>
